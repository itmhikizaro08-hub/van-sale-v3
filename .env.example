# Copy this to .env for local development. On Render, set these as
# environment variables in the dashboard instead — do not commit a real .env.

# A long random string. Render can auto-generate this (see render.yaml).
SECRET_KEY=change-me-to-a-random-string

# Password for the auto-created 'admin' account on first boot. Set this to
# something strong before your first production deploy — change it via the
# app immediately afterward regardless. Leave unset locally to use admin123.
ADMIN_PASSWORD=admin123

# Local development only — auto-creates 5 demo accounts (manager1, cashier1,
# rep1, supervisor1, warehouse1), all sharing the password "demo1234". Never
# set this to true on a real deployment.
SEED_DEMO_USERS=true

# Leave unset locally to use SQLite. On Render this is filled in automatically
# from the linked Postgres database (see render.yaml).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

COMPANY_NAME=Van Sales V3 ERP
COMPANY_PHONE=+233 XX XXX XXXX
COMPANY_EMAIL=info@vansalesv3.com
COMPANY_ADDRESS=Accra, Ghana

# Optional — SMS notifications (leave blank to disable)
SMS_PROVIDER=arkesel
ARKESEL_API_KEY=
ARKESEL_SMS_NAME=VanSales
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
